{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "db/run-sql.ts",
    "db/fill-examples.ts",
    "db/fill-pronunciation.ts",
    "db/cleanup-phrases.ts",
    "db/crawl-langmaster.ts",
    "db/post-crawl.ts",
    "db/analyze.ts",
    "db/debug-parse.ts",
    "db/fix-phrases.ts",
    "db/fix-translations.ts",
    "db/scan.ts",
    "db/seed.ts",
    "db/test-parser.ts"
  ]
}
